[Unit]
Description=claude-cellar FUSE mount for Claude Code sessions
Documentation=https://github.com/OnCeUponTry/claude-cellar
After=default.target

[Service]
Type=simple
ExecStart={{CELLAR_BIN}} mount --foreground
ExecStop={{CELLAR_BIN}} umount
Restart=on-failure
RestartSec=1
PrivateTmp=no

[Install]
WantedBy=default.target
